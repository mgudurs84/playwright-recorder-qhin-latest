modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
GCP_AGENT_PLANNER = "2955468563764215808"
GCP_AGENT_SEARCHER = "3132797799091929088"
GCP_AGENT_SYNTHESIZER = "7777134914817753088"

[nix]
channel = "stable-25_05"
packages = ["glib", "nss", "nspr", "atk", "cups", "dbus", "expat", "libGL", "libGLU", "libxkbcommon", "fontconfig", "freetype", "pango", "cairo", "alsa-lib", "at-spi2-atk", "at-spi2-core", "xorg.libX11", "xorg.libxcb", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXfixes", "xorg.libXrandr", "xorg.libXext", "xorg.libXi", "xorg.libXcursor", "xorg.libXrender", "xorg.libXtst", "mesa", "libgbm"]
