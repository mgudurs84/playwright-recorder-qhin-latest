# ─────────────────────────────────────────────────────────────────────────────
# CDR Observability — environment variables
#
# Copy this file to .env and fill in your values before running locally.
#   cp .env.example .env
#
# Lines marked [required] must be set. Lines marked [optional] have safe
# defaults and can be left commented out.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ───────────────────────────────────────────────────────────────────

# [required] Port the API server listens on.
# Replit sets this automatically. Locally use any free port.
PORT=3000


# ── CommonWell Portal Credentials ────────────────────────────────────────────

# [required] Your CommonWell portal login email
CW_USERNAME=your-username@example.com

# [required] Your CommonWell portal password
CW_PASSWORD=your-portal-password


# ── GCP / Vertex AI Auth (choose ONE of the two options below) ────────────────

# OPTION A — Local development with a service account JSON key file
# Paste the full contents of your GCP service account JSON on a single line.
# (The app handles escaped \n in the private_key automatically.)
# Leave commented out when deploying to GKE — use OPTION B instead.
#
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}


# OPTION B — GKE / Cloud Run with Workload Identity (Application Default Credentials)
# Set this to your GCP project ID. No JSON key file needed — GKE injects
# credentials automatically via the metadata server.
# Leave commented out if you are using OPTION A locally.
#
# GCP_PROJECT_ID=your-gcp-project-id


# ── Vertex AI Model Settings ──────────────────────────────────────────────────

# [optional] Gemini model to use for AI summarization.
# Default: gemini-2.5-flash
# VERTEX_MODEL_ID=gemini-2.5-flash

# [optional] Vertex AI region.
# Default: us-central1
# VERTEX_LOCATION=us-central1


# ── Session Management ────────────────────────────────────────────────────────

# [optional] How many hours a Playwright session cookie stays valid before
# the next run requires re-authentication (and a new OTP).
# Default: 24
# SESSION_MAX_AGE_HOURS=24


# ── Replit-specific (set automatically — do not set manually) ─────────────────

# REPLIT_DEV_DOMAIN   — injected by Replit; controls CORS for screenshot serving
# BASE_URL            — injected by Replit Vite plugin for the frontend base path
