# ── Server ────────────────────────────────────────────────────
PORT=8000

# ── CommonWell Credentials ─────────────────────────────────────
CW_USERNAME=your_commonwell_email@example.com
CW_PASSWORD=your_commonwell_password

# ── CW Portal ──────────────────────────────────────────────────
CW_PORTAL_URL=https://integration.commonwellalliance.lkopera.com

# ── GCP / Vertex AI — choose ONE of the two options below ──────
#
# OPTION A  (recommended for company/corporate use)
# Application Default Credentials (ADC) — no JSON key file needed.
# Steps:
#   1. Install gcloud CLI: https://cloud.google.com/sdk/docs/install
#   2. Run: gcloud auth application-default login
#   3. Set your GCP project ID below and leave GCP_SERVICE_ACCOUNT_JSON blank.
#
GCP_PROJECT_ID=your-gcp-project-id
#
# OPTION B  (service account JSON key — local dev without gcloud CLI)
# Paste the entire contents of your GCP key file on ONE single line.
# Leave this blank (or commented out) if you are using OPTION A.
#
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# ── Optional ───────────────────────────────────────────────────
VERTEX_MODEL_ID=gemini-2.5-flash
VERTEX_LOCATION=us-central1
SESSION_MAX_AGE_HOURS=24
