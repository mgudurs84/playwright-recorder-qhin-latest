# ── Server ────────────────────────────────────────────────────
PORT=8080

# ── CommonWell Credentials ─────────────────────────────────────
CW_USERNAME=your_commonwell_email@example.com
CW_PASSWORD=your_commonwell_password

# ── GCP / Vertex AI ───────────────────────────────────────────
# Option A: Service account JSON key (paste the entire JSON on one line)
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# Option B: If your company uses Workload Identity or ADC, leave the above
# blank and just set the project ID:
# GCP_PROJECT_ID=your-gcp-project-id

# ── Optional / Defaults ────────────────────────────────────────
# Which Gemini model to use (default: gemini-2.5-flash)
VERTEX_MODEL_ID=gemini-2.5-flash

# How long browser sessions stay alive before re-login (default: 24 hours)
SESSION_MAX_AGE_HOURS=24
